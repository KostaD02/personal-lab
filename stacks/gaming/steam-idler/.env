# Leave SERVER_IP empty to auto-detect the API address from the browser's URL;
# set it only to force a specific API host.
SERVER_IP=
SERVER_PORT=2221
CLIENT_PORT=2222

# Log types: 0 = none, 1 = error only, 2 = all
SERVER_LOG_TYPE=2
CLIENT_LOG_TYPE=2

JWT_EXPIRES_IN=1

# Generate with `pnpm g:secret` or `openssl rand -hex 64`
JWT_SECRET=REPLACE_ME_WITH_SECRET

# Encrypts Steam refresh tokens and web session cookies
# Generate with `pnpm g:secret` or `openssl rand -hex 64`
CREDENTIALS_SECRET=REPLACE_ME_WITH_SECRET

# Mongo (used when running the server outside docker; docker-compose overrides this
# internally to point at the `steam-idler-mongo` service on the compose network).
DATABASE_URL=mongodb://127.0.0.1:27018/steam-idler

# Cache. With REDIS_ENABLED=false an in-memory store is used (no Redis needed).
# REDIS_TTL is in milliseconds (300000 = 5 minutes).
REDIS_ENABLED=true
REDIS_HOST=localhost
REDIS_PORT=6379
# Leave empty unless your Redis requires a password (the bundled compose Redis doesn't).
REDIS_PASSWORD=
REDIS_TTL=300000
